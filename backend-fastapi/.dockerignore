# =============================================================================
# FinoraQi - .dockerignore
# Propósito: Excluir arquivos desnecessários do contexto de build Docker
# Impacto: Build mais rápido + imagem menor + segurança (sem secrets acidentais)
# =============================================================================

# -----------------------------------------------------------------------------
# Git & Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.github/

# -----------------------------------------------------------------------------
# Python Artifacts (não necessários na imagem)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual Environments (usamos multi-stage)
# -----------------------------------------------------------------------------
venv/
env/
.venv/
ENV/
.pytest_cache/
.mypy_cache/

# -----------------------------------------------------------------------------
# IDE & Editor Configs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Logs & Debug
# -----------------------------------------------------------------------------
*.log
logs/
debug.log
traceback.txt

# -----------------------------------------------------------------------------
# Environment & Secrets (CRÍTICO
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials.json

# -----------------------------------------------------------------------------
# Test & Coverage Reports
# -----------------------------------------------------------------------------
htmlcov/
.coverage
coverage.xml
*.coverage
.tox/
.nox/

# -----------------------------------------------------------------------------
# Documentation (já está na imagem via código, não precisa do source)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md  # Mantém README se quiser na imagem para debugging

# -----------------------------------------------------------------------------
# Frontend (se estiver no mesmo repo, não copiar para backend build)
# -----------------------------------------------------------------------------
frontend/
public/
static/
*.html
*.css
*.js
package*.json
node_modules/

# -----------------------------------------------------------------------------
# Docker Compose & K8s
# -----------------------------------------------------------------------------
docker-compose*.yml
*.yaml
k8s/
terraform/

# -----------------------------------------------------------------------------
# ML Artifacts
# -----------------------------------------------------------------------------
*.pkl
*.joblib
*.h5
*.onnx
models/trained/
!models/trained/.gitkeep
