# =============================================================================
# FINORAQI - TEMPLATE DE VARIÁVEIS DE AMBIENTE
# Copie para .env e preencha os valores
# NUNCA commitar o .env real no Git!
# =============================================================================

# # --- Ambiente ---
# ENV=development  # development | staging | production
# DEBUG=true       # Habilita logs detalhados (desativar em prod)

# # --- Servidor ---
# HOST=0.0.0.0
# PORT=8000
# WORKERS=4        # Número de workers Uvicorn (prod: 2x núcleos CPU)

# # --- Banco de Dados ---
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finoraqi
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# # --- Redis (cache/queue) ---
# REDIS_URL=redis://localhost:6379/0
# REDIS_PREFIX=finoraqi:

# # --- Segurança ---
# SECRET_KEY=gerar_com_openssl_rand_base64_32
# JWT_SECRET_KEY=outra_chave_forte_aleatoria_aqui
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# # --- CORS (frontend permitido) ---
# # Produção: liste apenas seus domínios
# CORS_ORIGINS=["http://localhost:8080", "https://finora-qi-website.vercel.app"]
# CORS_ALLOW_CREDENTIALS=true

# # --- ML Model ---
# ML_MODEL_PATH=./app/ml/models/v2.1.0-numba.pkl
# ML_FEATURE_VERSION=v2.1
# ML_CACHE_TTL=3600  # Cache de features em segundos

# # --- Logging & Monitoramento ---
# LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=json  # text | json (json é melhor para ELK/Prometheus)
# ENABLE_PROMETHEUS=true
# PROMETHEUS_PORT=9090

# # --- Email (notificações) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha_de_app_aqui
# EMAIL_FROM=noreply@finoraqi.com

# # --- Integrações Externas ---
# # APIs de geolocalização, reputação de IP, etc.
# IPINFO_API_KEY=opcional
# MAXMIND_LICENSE_KEY=opcional

# # --- Vercel/Deploy ---
# # Para frontend na Vercel:
# NEXT_PUBLIC_API_URL=https://seu-backend.railway.app